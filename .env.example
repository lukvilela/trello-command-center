# Trello API — gerar Power-Up em https://trello.com/power-ups/admin
TRELLO_KEY=replace_with_your_trello_api_key
TRELLO_TOKEN=replace_with_your_trello_token
TRELLO_BOARD_ID=replace_with_your_board_short_id

# Secret compartilhado pelo time (qualquer string forte) — exigido pra escrita
TRYEVO_DASH_SECRET=mude-esta-senha-pra-uma-forte
